# DECEPTRA Configuration
# Copy this file to .env and customize values

# Application
APP_NAME=DECEPTRA
APP_VERSION=1.0.0
DEBUG=True

# Database
# SQLite: sqlite:///./deceptra.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost/deceptra
DATABASE_URL=sqlite:///./deceptra.db

# Logging
LOG_LEVEL=INFO
MAX_BODY_LOG_SIZE=10000

# Request timeout (milliseconds)
REQUEST_TIMEOUT_MS=30000

# CORS
CORS_ORIGINS=["*"]
